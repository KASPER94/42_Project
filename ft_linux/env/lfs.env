# shellcheck shell=bash
#
# env/lfs.env — the single source of truth for the ft_linux build
# =============================================================================
# THIS FILE IS SOURCED BY EVERY SCRIPT IN THE SUITE.
#
#     source "<repo>/env/lfs.env"
#
# It defines the core build identity (where LFS lives, the cross-compile
# target triplet, the student login, locale, PATH, MAKEFLAGS) and then sources
# its two siblings:
#     env/versions.sh   — pinned package versions + download URLs
#     env/paths.sh      — derived disk/partition/state/log paths
#
# Sourcing this one file therefore brings the ENTIRE contract into scope.
#
# It must be POSIX-sh sourceable (no bashisms in this file) so it works from
# the lfs build user's plain shell, from inside chroot, and from bash scripts.
# It is intentionally idempotent: sourcing twice is harmless.
# =============================================================================

# -----------------------------------------------------------------------------
# Locate our own directory robustly, regardless of how we were sourced and
# regardless of the caller's CWD. ${BASH_SOURCE} when run under bash; fall back
# to $0 for plain POSIX sh. We resolve to an absolute directory.
# -----------------------------------------------------------------------------
if [ -n "${BASH_SOURCE:-}" ]; then
	_lfs_env_self="${BASH_SOURCE}"
else
	_lfs_env_self="$0"
fi
# Directory containing this file (env/). CDPATH unset to avoid surprises.
LFS_ENV_DIR="$(CDPATH= cd -- "$(dirname -- "$_lfs_env_self")" && pwd -P)"
# Repository root is the parent of env/.
FT_REPO_ROOT="$(CDPATH= cd -- "$LFS_ENV_DIR/.." && pwd -P)"
unset _lfs_env_self

# -----------------------------------------------------------------------------
# Core build identity  (LFS Ch.2/4)
# -----------------------------------------------------------------------------

# Mount point of the LFS target filesystem on the build host.
LFS=/mnt/lfs

# Cross-compilation target triplet (64-bit, per the fixed decisions).
LFS_TGT=x86_64-lfs-linux-gnu

# Student login. THE single place this string is defined. It MUST appear in:
#   * the hostname                 (system-config)
#   * the kernel localversion       -> uname -r ends with "-skapers"
#   * the kernel binary name         /boot/vmlinuz-<version>-skapers
# Spec rule R7/R4/R5. Do not duplicate this literal anywhere else.
LFS_USER_LOGIN=skapers

# Locale used during the build so tool output is predictable and parseable.
LC_ALL=POSIX

# Parallel make: use every available core. nproc lives in coreutils; on the
# bootstrap host it is always present. Fall back to 1 if nproc is missing.
if command -v nproc >/dev/null 2>&1; then
	MAKEFLAGS="-j$(nproc)"
else
	MAKEFLAGS="-j1"
fi

# config.site is consulted by autoconf-configured packages; the LFS book points
# it at a file under $LFS so cross/native configure behaves consistently.
CONFIG_SITE="$LFS/usr/share/config.site"

# -----------------------------------------------------------------------------
# PATH for the lfs build user
# -----------------------------------------------------------------------------
# During the toolchain/temp-tools phases the freshly built tools in
# $LFS/tools/bin MUST come first, ahead of the host's /usr/bin:/bin. The LFS
# book sets exactly this for the `lfs` user. (Inside chroot a different,
# system PATH is used; that is set by lib/chroot-helpers.sh's env -i, not here.)
PATH="$LFS/tools/bin:/usr/bin:/bin"

# umask 022 so freshly created files/dirs have sane permissions during build.
umask 022

# -----------------------------------------------------------------------------
# Export the core identity.
# -----------------------------------------------------------------------------
export LFS LFS_TGT LFS_USER_LOGIN LC_ALL MAKEFLAGS CONFIG_SITE PATH
export LFS_ENV_DIR FT_REPO_ROOT

# -----------------------------------------------------------------------------
# Pull in the rest of the contract. Order matters: versions first (no deps),
# then paths (may reference $LFS, set above).
# -----------------------------------------------------------------------------
# shellcheck source=./versions.sh
. "$LFS_ENV_DIR/versions.sh"
# shellcheck source=./paths.sh
. "$LFS_ENV_DIR/paths.sh"
