#!/usr/bin/env python3
"""Executable entry point for Learn2Slither.

Keeps the repo runnable straight from a clone with no install step: it puts the
``src`` directory on the import path and delegates to the CLI.
"""

from __future__ import annotations

import os
import sys

_SRC = os.path.join(os.path.dirname(os.path.abspath(__file__)), "src")
if _SRC not in sys.path:
    sys.path.insert(0, _SRC)

from learn2slither.cli import main  # noqa: E402  (path set up above)

if __name__ == "__main__":
    sys.exit(main())
